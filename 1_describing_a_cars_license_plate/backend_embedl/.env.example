# =======================================================
# Configurations of backend_embedl
# Copy this file to .env and adjust as needed.
# =======================================================

# ---- App ----
APP_NAME="License Plate Analyzer API"
APP_VERSION=0.1.0

# ---- Server ----
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ---- CORS (lista JSON em uma unica linha) ----
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:4173"]

# ---- Modelo VLM ----
MODEL_NAME=embedl/Cosmos-Reason2-2B-W4A16
# DEVICE: auto | cuda | cpu | mps
DEVICE=auto
# DTYPE: auto | float16 | float32 | bfloat16
DTYPE=auto
ATTN_IMPLEMENTATION=sdpa
MAX_NEW_TOKENS=600
REPETITION_PENALTY=1.05
# VIDEO_FPS: fps for frame extraction from videos (default=2, higher = more precise, slower)
VIDEO_FPS=4

# ---- Upload ----
MAX_UPLOAD_MB=100

# ---- Jobs ----
JOB_TTL_MINUTES=30
JOB_CLEANUP_INTERVAL_SECONDS=300

# ---- API ----
API_V1_PREFIX=/api/v1
